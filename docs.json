{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Microset",
  "description": "A non-custodial prediction market on Solana — security and transparency documentation.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "icon": "shield-check",
            "pages": [
              "security/introduction",
              "security/review-summary"
            ]
          },
          {
            "group": "Using Microset",
            "icon": "wallet",
            "pages": [
              "security/user-flow",
              "security/wallet-interactions"
            ]
          },
          {
            "group": "Contract & Security",
            "icon": "file-code",
            "pages": [
              "security/contracts",
              "security/smart-contract",
              "security/security-assessment",
              "security/transaction-safety"
            ]
          },
          {
            "group": "Data & Compliance",
            "icon": "scale",
            "pages": [
              "security/data-privacy",
              "security/compliance-and-risk-disclosure"
            ]
          }
        ]
      },
      {
        "tab": "Legal",
        "groups": [
          {
            "group": "Policies",
            "icon": "gavel",
            "pages": [
              "legal/terms-and-conditions",
              "legal/privacy-policy",
              "legal/data-policy"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.microset.io"
    }
  },
  "footer": {
    "socials": {}
  }
}
